# ══════════════════════════════════════
#  TalkPC 서버 환경변수 예시
#  .env 파일로 복사 후 실제 값 입력
# ══════════════════════════════════════

DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/talkpc
JWT_SECRET=랜덤-시크릿-키-여기에-입력
API_SECRET_KEY=프로그램-내장-API-키
SMTP_USER=your@gmail.com
SMTP_PASSWORD=gmail-앱-비밀번호
WIDESHOT_API_URL=https://apimsg.wideshot.co.kr
WIDESHOT_API_KEY=와이드샷-API-키
WIDESHOT_CALLBACK=등록된-발신번호
SEND_METHOD=api
ALLOWED_ORIGINS=http://localhost:8000
